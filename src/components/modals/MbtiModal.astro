---
/* MbtiModal — INTP-A personality profile, design matches other modals */
import Modal from "../Modal.astro";
import { testData, traitColors, traitTypes, traitDescriptions, profileLink } from "../../data/mbti.js";

const d = testData.historical; /* INTP-A — Feb 10, 2025 */
---

<Modal modalId="modal-mbti" title="Personality">
  <div class="space-y-6">

    <!-- ── Type + role header ─────────────────────────────── -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-sm font-semibold text-white leading-snug">{d.type}</h3>
        <p class="text-xs text-gray-600 mt-1">{d.role.title} · {d.strategy.title}</p>
      </div>
      <span class="text-xs text-gray-600 whitespace-nowrap mt-0.5">{d.date}</span>
    </div>

    <!-- Personality description -->
    <p class="text-sm text-gray-400 leading-relaxed">{d.personality.description}</p>

    <!-- ── Role + Strategy ─────────────────────────── -->
    <div class="pb-6 border-b border-gray-800 space-y-4">
      <div>
        <p class="text-xs text-gray-600 mb-1.5 uppercase tracking-widest">Role</p>
        <p class="text-sm text-gray-400 leading-relaxed">{d.role.description}</p>
      </div>
      <div>
        <p class="text-xs text-gray-600 mb-1.5 uppercase tracking-widest">Strategy</p>
        <p class="text-sm text-gray-400 leading-relaxed">{d.strategy.description}</p>
      </div>
    </div>

    <!-- ── Trait axes ──────────────────────────────────────── -->
    <div>
      <p class="text-xs text-gray-600 uppercase tracking-widest mb-4">Traits</p>
      <div class="space-y-5">
        {d.traits.map((t) => {
          const color = traitColors[t.trait] ?? "6B7280";
          const type  = traitTypes[t.trait] ?? "";
          const desc  = traitDescriptions[t.trait] ?? "";
          return (
            <div>
              <!-- Labels -->
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-3">
                  <span class="text-xs text-gray-700 w-16 uppercase tracking-widest">{type}</span>
                  <span class="text-xs font-semibold text-white">{t.trait}</span>
                </div>
                <span class="text-xs text-gray-700">{t.opposite}</span>
              </div>
              <!-- Bar -->
              <div class="relative h-px bg-gray-800">
                <div
                  class="absolute top-0 left-0 h-full"
                  style={`width:${t.percentage}%; background-color:#${color}`}
                ></div>
              </div>
              <!-- Percentage + desc -->
              <div class="flex justify-between mt-1.5 mb-1.5">
                <span class="text-xs text-gray-600">{t.percentage}%</span>
                <span class="text-xs text-gray-700">{100 - t.percentage}%</span>
              </div>
              <p class="text-xs text-gray-600 leading-relaxed pl-3 relative before:content-[''] before:absolute before:left-0 before:top-1.5 before:w-1 before:h-1 before:bg-gray-800 before:rounded-full">
                {desc}
              </p>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── External link ───────────────────────────────────── -->
    <a
      href={profileLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block text-xs text-gray-600 hover:text-white transition-all duration-200 ease-in-out"
    >
      Full Profile →
    </a>

  </div>
</Modal>
