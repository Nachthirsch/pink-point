---
/* CertificatesModal — dark-themed certificates with live credential links */
import Modal from "../Modal.astro";
import { certificates } from "../../data/certificates.js";
---

<Modal modalId="modal-certificates" title="Certificates">
  <div class="space-y-0">
    {certificates.map((cert, index) => (
      <div class:list={[
        "flex items-start justify-between gap-4 py-4",
        index < certificates.length - 1 ? "border-b border-gray-800" : ""
      ]}>

        <!-- Name + issuer -->
        <div class="flex-1 min-w-0">
          <h3 class="text-sm font-semibold text-white leading-snug">{cert.name}</h3>
          <p class="mt-0.5 text-xs text-gray-500">{cert.issuer}</p>
        </div>

        <!-- Date + Verify link -->
        <div class="flex flex-col items-end gap-1.5 shrink-0 text-right">
          <span class="text-xs text-gray-600">{cert.date}</span>
          {cert.credential && (
            <a
              href={cert.credential}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium tracking-wider uppercase text-gray-600 hover:text-white transition-all duration-200 ease-in-out"
            >
              Verify →
            </a>
          )}
        </div>

      </div>
    ))}
  </div>
</Modal>
