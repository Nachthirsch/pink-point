---
/* ExperienceModal — dark-themed work history content */
import Modal from "../Modal.astro";
import { experience } from "../../data/experience.js";
---

<Modal modalId="modal-experience" title="Experience">
  <div class="space-y-6">
    {experience.map((job, index) => (
      <div class:list={["pb-6", index < experience.length - 1 ? "border-b border-gray-800" : ""]}>
        <!-- Role + period -->
        <div class="flex items-start justify-between gap-4">
          <h3 class="text-sm font-semibold text-white leading-snug">{job.role}</h3>
          <span class="text-xs text-gray-600 whitespace-nowrap mt-0.5">{job.period}</span>
        </div>

        <!-- Company + location -->
        <p class="text-xs text-gray-600 mt-1">{job.company} · {job.location}</p>

        <!-- Details -->
        <ul class="mt-3 space-y-1.5">
          {job.details.map((detail) => (
            <li class="text-sm leading-relaxed text-gray-400 pl-3 relative before:content-[''] before:absolute before:left-0 before:top-2 before:w-1 before:h-1 before:bg-gray-700 before:rounded-full">
              {detail}
            </li>
          ))}
        </ul>

        <!-- Tags -->
        {job.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {job.tags.map((tag) => (
              <span class="text-xs px-2 py-0.5 border border-gray-800 text-gray-500 rounded-none">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</Modal>
