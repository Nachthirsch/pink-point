---
/* Modal — dark-themed modal matching the main page aesthetic */
interface Props {
  modalId: string;
  title: string;
}

const { modalId, title } = Astro.props;
---

<!-- Modal container -->
<div
  id={modalId}
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${modalId}-title`}
  class="modal fixed inset-0 z-50 flex items-center justify-center hidden"
>
  <div class="modal-panel bg-[#111111] border border-gray-800 w-full max-w-2xl max-h-[80vh] overflow-hidden relative flex flex-col mx-4">
    <!-- Modal header — sticky top -->
    <div class="px-8 pt-7 pb-4 border-b border-gray-800 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <!-- Decorative accent bar matching main card style -->
        <span class="w-px h-5 bg-gray-700 inline-block"></span>
        <h2 id={`${modalId}-title`} class="text-sm font-semibold tracking-[0.15em] uppercase text-white">{title}</h2>
      </div>
      <button
        type="button"
        class="modal-close text-gray-700 hover:text-white transition-all duration-200 ease-in-out cursor-pointer focus:outline-none"
        aria-label="Close modal"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Modal content — scrollable -->
    <div class="modal-content overflow-y-auto px-8 py-6">
      <slot />
    </div>
  </div>
</div>
